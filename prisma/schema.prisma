// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              Int            @id @default(autoincrement())
  name            String         @db.VarChar(255)
  email           String         @unique @db.VarChar(255)
  password        String
  role            String         @db.VarChar(50)   // "admin" | "pensioner"
  pensioner_type  PensionerType?
  qr_token        String?        @unique @db.VarChar(255)
  balance         Decimal        @default(0) @db.Decimal(10, 2)
  first_login     Boolean        @default(true)
  is_active       Boolean        @default(true)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  orders       Order[]
  sales        Sale[]
  consumptions Consumption[]
  movements    BalanceMovement[]

  @@map("users")
}

// ─── Enums ───────────────────────────────────────────────

enum PensionerType {
  ESTUDIANTE
  TRABAJADOR
}

enum MealType {
  DESAYUNO
  ALMUERZO
  CENA
}

enum Categoria {
  ENTRADA
  MENU
}

// ─── Productos ───────────────────────────────────────────

model Producto {
  id          Int       @id @default(autoincrement())
  nombre      String
  descripcion String?
  precio      Decimal   @db.Decimal(10, 2)
  imagen      String?
  categoria   Categoria
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  menus       MenusProductos[]
  orderItems  OrderItem[]
  saleItems   SaleItem[]

  @@map("productos")
}

// ─── Menus ───────────────────────────────────────────────

model Menus {
  id        String   @id @default(cuid())
  nombre    String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  productos MenusProductos[]

  @@map("menus")
}

// ─── MenusProductos (pivot) ──────────────────────────────

model MenusProductos {
  id         String   @id @default(cuid())
  menuId     String
  productoId Int
  visible    Boolean  @default(true)
  createdAt  DateTime @default(now())

  menu     Menus    @relation(fields: [menuId], references: [id])
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@unique([menuId, productoId])
  @@map("menus_productos")
}

enum OrderType {
  MESA
  PARA_LLEVAR
}

enum CustomerType {
  REGULAR
  PENSIONER
}

enum OrderStatus {
  ACTIVE
  CONFIRMED
}

enum PaymentMethod {
  EFECTIVO
  YAPE
}

model Order {
  id           String       @id @default(cuid())
  tableNumber  String?
  type         OrderType
  customerType CustomerType @default(REGULAR)
  pensionerId  Int?
  status       OrderStatus  @default(ACTIVE)
  total        Decimal      @default(0) @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  pensioner User?       @relation(fields: [pensionerId], references: [id])
  items     OrderItem[]

  @@index([status])
  @@index([type])
  @@index([pensionerId])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productoId  Int
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  isTakeaway  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productoId])
  @@map("order_items")
}

model Sale {
  id            String       @id @default(cuid())
  sourceOrderId String?      @unique
  tableNumber   String?
  type          OrderType
  customerType  CustomerType @default(REGULAR)
  pensionerId   Int?
  customerLabel String?
  total         Decimal      @db.Decimal(10, 2)
  soldAt        DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  pensioner User?         @relation(fields: [pensionerId], references: [id])
  items     SaleItem[]
  payments  SalePayment[]

  @@index([soldAt])
  @@index([type])
  @@index([pensionerId])
  @@map("sales")
}

model SaleItem {
  id          String   @id @default(cuid())
  saleId      String
  productoId  Int?
  productName String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  subtotal    Decimal  @db.Decimal(10, 2)
  isTakeaway  Boolean  @default(false)
  createdAt   DateTime @default(now())

  sale     Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  producto Producto? @relation(fields: [productoId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productoId])
  @@map("sale_items")
}

model SalePayment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
  @@map("sale_payments")
}

// ─── Consumos de Pensionistas ────────────────────────────

model Consumption {
  id         String   @id @default(cuid())
  userId     Int
  mealType   MealType
  amount     Decimal  @db.Decimal(10, 2)
  date       DateTime @default(now())
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([date])
  @@index([userId, date])
  @@map("consumptions")
}

// ─── Configuración de Precios (Trabajadores) ─────────────

model PriceConfig {
  id        String   @id @default(cuid())
  mealType  MealType @unique
  price     Decimal  @db.Decimal(10, 2)
  updatedAt DateTime @updatedAt

  @@map("price_config")
}

// ─── Movimientos de Saldo ────────────────────────────────

enum MovementType {
  RECARGA
  CONSUMO
  AJUSTE
}

model BalanceMovement {
  id          String       @id @default(cuid())
  userId      Int
  type        MovementType
  amount      Decimal      @db.Decimal(10, 2)
  balance     Decimal      @db.Decimal(10, 2)  // saldo resultante después del movimiento
  description String?
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@map("balance_movements")
}
